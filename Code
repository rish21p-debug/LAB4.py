    """

    def __init__(self): # You are not allowed to modify the constructor
        self.head = None
    
    def __repr__(self):  # You are not allowed to modify this method
        current = self.head
        out = []
        while current != None:
            out.append(str(current.value))
            current = current.next
        return " -> ".join(out)

    __str__ = __repr__
    
    def __len__(self):
        # Task: Count how many nodes are inside our linked list
        # Input: The current list object
        # Output: An integer representing total node count
        
        # Starts a counter at zero
        count = 0
        # Starts checking from the front node
        current = self.head
        
        # Keeps on moving forward until the nodes run out
        while current is not None:
            count += 1
            current = current.next
            
        return count

    
    def __setitem__(self, pos, value):
        # Task for program: Find a node at a specific slot and update its value
        # Input: A target index position and a new value
        # Output: None
        
        # Stops and throw an index error if the index number is invalid or out of bounds
        if pos < 0 or pos >= len(self):
            raise IndexError()
        
        # Goes to the specified position
        current = self.head
        index = 0
        while index < pos:
            assert current is not None 
            current = current.next
            index += 1
            
        # Swaps out the old value with the new one
        assert current is not None     
        current.value = value


    def __getitem__(self, pos):
        # Task for program: Retrieve the value stored inside a node at a specific position
        # Input: A target index position
        # Output: The data value stored at that index position
        
        # If the list is empty, returns None
        if self.head is None:
            return None
            
        # Stops and raises an error if the index number is out of bounds
        if pos < 0 or pos >= len(self):
            raise IndexError()
            
        # Goes to the specified position
        current = self.head
        index = 0
        while index < pos:
            assert current is not None  
            current = current.next
            index += 1
            
        # Returns the value found inside the node
        assert current is not None     
        return current.value
    

    def malloc(self, size):
        # Task for program: Build a brand new linked list chain filled with None values
        # Input: A positive integer size for the chain
        # Output: None
        
        # If size is invalid, the function stops
        if size <= 0:
            self.free()
            return
            
        # Specifies the very first front node
        self.head = Node(None)
        current = self.head
        
        # Chains together the remaining nodes one by one
        count = 1
        while count < size:
            assert current is not None
            current.next = Node(None)
            current = current.next
            count += 1


    def calloc(self, size):
        # Task for program: Build a brand new linked list chain filled entirely with zeros
        # Input: A positive integer size for the chain
        # Output: None
        
        # If size is invalid, the function stops
        if size <= 0:
            self.free()
            return
            
        # Specifies the very first front node with a zero
        self.head = Node(0)
        current = self.head
        
        # Chains together the remaining nodes that are filled with zeros
        count = 1
        while count < size:
            assert current is not None 
            current.next = Node(0)
            current = current.next
            count += 1


    def free(self):
        # Task for program: Break apart every individual link between nodes to clear memory
        # Input: The list object
        # Output: None
        
        # Holds onto the front node first
        current = self.head
        # Removes the main head pointer entirely
        self.head = None
        
        # Disconnects every single node link one at a time so they are completely unlinked
        while current is not None:
            next_node = current.next
            current.next = None
            current = next_node


    def realloc(self, size):
        # Task for program: Shrink or grow our list chain to match a new specified size
        # Input: A non-negative integer size
        # Output: None
        
        current_len = len(self)
        
        # If target size is 0, returns nothing
        if size == 0:
            self.free()
            return
            
        # Checks if the list is empty
        if current_len == 0:
            self.malloc(size)
            return
            
        # If the size is growing, go to the end and add on extra None nodes
        if size > current_len:
            current = self.head
            assert current is not None  
            while current.next is not None:
                current = current.next
                
            needed = size - current_len
            while needed > 0:
                assert current is not None  
                current.next = Node(None)
                current = current.next
                needed -= 1
                
        # If list is shrinking, go to the cutoff point and unlink all tail nodes
        elif size < current_len:
            current = self.head
            index = 1
            while index < size:
                assert current is not None  
                current = current.next
                index += 1
                
            # Isolates the remaining chain pieces and break the connection
            assert current is not None      
            to_disconnect = current.next
            current.next = None
            
            # Unlinks the leftover nodes one at a time
            while to_disconnect is not None:
                next_node = to_disconnect.next
                to_disconnect.next = None
                to_disconnect = next_node


    def memcpy(self, ptr1_start_idx, pointer_2, ptr2_start_idx, size):
        # Task for program: Copy segment values from our list over into a target second list
        # Input: Starting index from source, destination list, starting index for destination, and a copy size
        # Output: None
        
        len1 = len(self)
        len2 = len(pointer_2)
        
        # Checks if either start index is out of bounds
        if ptr1_start_idx >= len1 or ptr2_start_idx >= len2:
            return
            
        # Goes to the starting slot in the original source list
        curr1 = self.head
        idx1 = 0
        while idx1 < ptr1_start_idx and curr1 is not None:
            curr1 = curr1.next
            idx1 += 1
            
        # Goes to the starting slot in the target list
        curr2 = pointer_2.head
        idx2 = 0
        while idx2 < ptr2_start_idx and curr2 is not None:
            curr2 = curr2.next
            idx2 += 1
            
        copied = 0
        while copied < size and curr1 is not None and curr2 is not None:
            curr2.value = curr1.value
            curr1 = curr1.next
            curr2 = curr2.next
            copied += 1
    

